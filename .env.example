# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://notebooklm:secret@localhost:5432/notebooklm

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# QDRANT
# ============================================================
QDRANT_URL=http://localhost:6333

# ============================================================
# MINIO / S3
# ============================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=notebooklm-assets
MINIO_USE_SSL=false

# ============================================================
# AUTH
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# AI PROVIDERS
# ============================================================
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# ============================================================
# EMBEDDING
# ============================================================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ============================================================
# SERVICE PORTS
# ============================================================
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
VAULT_SERVICE_PORT=3002
GRAPH_SERVICE_PORT=3003
SEARCH_SERVICE_PORT=3004
AI_SERVICE_PORT=3005
EMBEDDING_SERVICE_PORT=3006
MEDIA_SERVICE_PORT=3007
WEB_PORT=3008

# ============================================================
# INTERNAL SERVICE URLS (for docker-compose)
# ============================================================
AUTH_SERVICE_URL=http://auth-service:3001
VAULT_SERVICE_URL=http://vault-service:3002
GRAPH_SERVICE_URL=http://graph-service:3003
SEARCH_SERVICE_URL=http://search-service:3004
AI_SERVICE_URL=http://ai-service:3005
EMBEDDING_SERVICE_URL=http://embedding-service:3006
MEDIA_SERVICE_URL=http://media-service:3007

# ============================================================
# NEXT.JS (PUBLIC — exposed to browser)
# ============================================================
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NotebookLM Clone

# ============================================================
# MISC
# ============================================================
NODE_ENV=development
LOG_LEVEL=debug
